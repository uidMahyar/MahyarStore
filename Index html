function closeProductForm() { $('#product-form-overlay')?.classList.remove('open'); }
function saveProduct() {
  const name=$('#pf-name').value.trim(), cat=$('#pf-category').value, price=+$('#pf-price').value, stock=+$('#pf-stock').value, image=$('#pf-image').value, desc=$('#pf-desc').value.trim();
  if(!name||!cat||!price){ showToast('نام، دسته‌بندی و قیمت الزامی است','toast-error'); return; }
  Store.update(d => {
    const obj = { id: editingProductId||Date.now(), name, category:cat, price, comparePrice:+$('#pf-compare').value||0, stock, badge:$('#pf-badge').value.trim(), featured:$('#pf-featured').checked, description:desc, image };
    if (editingProductId) { const idx=d.products.findIndex(p=>p.id===editingProductId); if(idx>-1) d.products[idx]=obj; }
    else d.products.push(obj);
  });
  closeProductForm(); showToast('محصول ذخیره شد','toast-success'); renderProductsTable();
}
function deleteProduct(id) {
  if(!confirm('آیا از حذف این محصول مطمئن هستید؟')) return;
  Store.update(d => { d.products=d.products.filter(p=>p.id!==id); });
  showToast('محصول حذف شد'); renderProductsTable();
}


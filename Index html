<!DOCTYPE html>
<html lang="fa" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover">
<title>ویترین | فروشگاه آنلاین</title>
<meta name="description" content="فروشگاه آنلاین با محصولات متنوع و قیمت مشخص">
<link rel="icon" type="image/svg+xml" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%235C2A52'/%3E%3Cpath d='M30 40h40l-4 35a6 6 0 0 1-6 5H40a6 6 0 0 1-6-5z' fill='none' stroke='%23F3F1EB' stroke-width='6'/%3E%3Cpath d='M38 40v-8a12 12 0 0 1 24 0v8' fill='none' stroke='%23F3F1EB' stroke-width='6'/%3E%3C/svg%3E">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Estedad:wght@400;500;600;700;800;900&family=Vazirmatn:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
<style>
/* ============ TOKENS ============ */
:root{
  --bg:#F3F1EB;
  --surface:#FFFFFF;
  --surface-2:#FAF8F4;
  --ink:#211A2E;
  --ink-soft:#6B6358;
  --ink-faint:#9C9588;
  --primary:#5C2A52;
  --primary-dark:#421D3A;
  --primary-soft:#F0E3ED;
  --secondary:#C28A2E;
  --secondary-soft:#FAF0DC;
  --success:#3F6B4F;
  --success-soft:#E6F0E8;
  --danger:#B5453A;
  --danger-soft:#FBEAE8;
  --border:#E4DFD3;
  --radius-card:16px;
  --radius-btn:10px;
  --radius-pill:999px;
  --shadow-sm:0 1px 2px rgba(33,26,46,.07);
  --shadow-md:0 10px 28px rgba(33,26,46,.10);
  --shadow-lg:0 26px 64px rgba(33,26,46,.20);
  --font-display:'Estedad',Vazirmatn,sans-serif;
  --font-body:'Vazirmatn','Estedad',sans-serif;
  --transition:200ms cubic-bezier(.4,0,.2,1);
  --header-h:72px;
}
*,*::before,*::after{ box-sizing:border-box; }
*{ margin:0; padding:0; }
html{ -webkit-text-size-adjust:100%; }
body{
  font-family:var(--font-body);
  background:var(--bg);
  color:var(--ink);
  line-height:1.6;
  font-size:16px;
  -webkit-font-smoothing:antialiased;
  transition:background var(--transition), color var(--transition);
}
img{ max-width:100%; display:block; }
button{ font-family:inherit; cursor:pointer; }
input,textarea,select{ font-family:inherit; font-size:1rem; }
a{ color:inherit; text-decoration:none; }
ul{ list-style:none; }
.container{ max-width:1240px; margin-inline:auto; padding-inline:clamp(16px,4vw,32px); }
h1,h2,h3,h4{ font-family:var(--font-display); font-weight:800; }
:focus-visible{ outline:2.5px solid var(--secondary); outline-offset:2px; border-radius:4px; }
.no-scroll{ overflow:hidden; }
@media (prefers-reduced-motion: reduce){
  *{ animation-duration:0.001ms !important; transition-duration:0.001ms !important; }
}

/* ============ BUTTONS ============ */
.btn{
  display:inline-flex; align-items:center; justify-content:center; gap:8px;
  padding:13px 22px; border-radius:var(--radius-btn); border:1.5px solid transparent;
  font-weight:600; font-size:.95rem; transition:transform var(--transition), box-shadow var(--transition), background var(--transition), border-color var(--transition), color var(--transition);
  white-space:nowrap;
}
.btn:active{ transform:scale(.97); }
.btn-block{ width:100%; }
.btn-primary{ background:var(--primary); color:#fff; }
.btn-primary:hover{ background:var(--primary-dark); box-shadow:var(--shadow-md); }
.btn-outline{ background:transparent; border-color:var(--border); color:var(--ink); }
.btn-outline:hover{ border-color:var(--primary); color:var(--primary); }
.btn-ghost{ background:transparent; color:var(--ink-soft); padding:10px 14px; }
.btn-ghost:hover{ color:var(--ink); background:var(--surface-2); }
.btn-danger{ background:var(--danger-soft); color:var(--danger); }
.btn-danger:hover{ background:var(--danger); color:#fff; }
.btn-sm{ padding:8px 14px; font-size:.85rem; }
.btn-icon{ padding:10px; border-radius:var(--radius-pill); background:transparent; color:var(--ink); position:relative; }
.btn-icon:hover{ background:var(--surface-2); }
.btn[disabled]{ opacity:.5; cursor:not-allowed; }

/* ============ FORMS ============ */
.field{ display:flex; flex-direction:column; gap:6px; margin-bottom:16px; }
.field label{ font-size:.85rem; font-weight:600; color:var(--ink-soft); }
.field .hint{ font-size:.78rem; color:var(--ink-faint); font-weight:400; }
.field input[type=text],.field input[type=tel],.field input[type=email],.field input[type=number],.field input[type=password],.field textarea,.field select{
  padding:12px 14px; border:1.5px solid var(--border); border-radius:10px; background:var(--surface); color:var(--ink); width:100%; transition:border-color var(--transition);
}
.field input:focus,.field textarea:focus,.field select:focus{ border-color:var(--primary); outline:none; }
.field textarea{ resize:vertical; min-height:90px; }
.field-row{ display:grid; grid-template-columns:1fr 1fr; gap:14px; }
@media(max-width:520px){ .field-row{ grid-template-columns:1fr; } }
.checkbox-row{ display:flex; align-items:center; gap:10px; }
.checkbox-row input{ width:18px; height:18px; accent-color:var(--primary); }

/* ============ TOAST ============ */
.toast{
  position:fixed; bottom:24px; left:50%; transform:translateX(-50%) translateY(20px);
  background:var(--ink); color:var(--bg); padding:13px 22px; border-radius:var(--radius-pill);
  font-size:.9rem; font-weight:600; box-shadow:var(--shadow-lg); opacity:0; pointer-events:none;
  transition:opacity var(--transition), transform var(--transition); z-index:9999; max-width:90vw; text-align:center;
}
.toast.show{ opacity:1; transform:translateX(-50%) translateY(0); }
.toast.toast-error{ background:var(--danger); color:#fff; }
.toast.toast-success{ background:var(--success); color:#fff; }

/* ============ HEADER ============ */
.site-header{
  position:sticky; top:0; z-index:500; background:rgba(243,241,235,.88); backdrop-filter:blur(10px);
  border-bottom:1px solid transparent; transition:border-color var(--transition), box-shadow var(--transition);
  height:var(--header-h); display:flex; align-items:center;
}
.site-header.scrolled{ border-color:var(--border); box-shadow:var(--shadow-sm); }
.site-header__inner{ display:flex; align-items:center; justify-content:space-between; gap:16px; width:100%; }
.site-header__logo{ font-family:var(--font-display); font-weight:800; font-size:1.4rem; color:var(--ink); display:flex; align-items:center; gap:8px; }
.site-header__logo-mark{ width:34px; height:34px; border-radius:9px; background:var(--primary); display:flex; align-items:center; justify-content:center; color:#fff; flex-shrink:0; }
.site-header__nav{ display:none; align-items:center; gap:6px; }
@media(min-width:760px){ .site-header__nav{ display:flex; } }
.site-header__nav a{ padding:9px 14px; border-radius:var(--radius-pill); color:var(--ink-soft); font-weight:600; font-size:.92rem; transition:background var(--transition),color var(--transition); }
.site-header__nav a:hover{ background:var(--surface-2); color:var(--ink); }
.site-header__actions{ display:flex; align-items:center; gap:4px; }
.cart-btn{ position:relative; }
.cart-badge{
  position:absolute; top:2px; left:2px; background:var(--secondary); color:#fff; font-size:.65rem; font-weight:800;
  min-width:17px; height:17px; border-radius:99px; display:flex; align-items:center; justify-content:center; padding-inline:3px;
}
.menu-toggle{ display:flex; }
@media(min-width:760px){ .menu-toggle{ display:none; } }
.mobile-nav{
  position:fixed; inset:var(--header-h) 0 0 0; background:var(--bg); z-index:480; padding:20px;
  transform:translateY(-12px); opacity:0; pointer-events:none; transition:transform var(--transition),opacity var(--transition);
}
.mobile-nav.open{ transform:translateY(0); opacity:1; pointer-events:auto; }
.mobile-nav a{ display:block; padding:16px 6px; font-size:1.1rem; font-weight:700; border-bottom:1px solid var(--border); }

/* ============ HERO ============ */
.hero{ padding-block:clamp(36px,7vw,80px) clamp(46px,7vw,76px); background:var(--surface-2); overflow:hidden; }
.hero__inner{ display:grid; grid-template-columns:1fr; gap:30px; align-items:center; }
@media(min-width:900px){ .hero__inner{ grid-template-columns:1.05fr 1fr; gap:52px; } }
.hero__eyebrow{ display:inline-flex; align-items:center; gap:7px; font-size:.78rem; font-weight:700; color:var(--secondary); background:var(--secondary-soft); padding:6px 13px; border-radius:var(--radius-pill); margin-bottom:18px; }
.hero__title{ font-size:clamp(2rem,4.4vw,3.3rem); line-height:1.18; color:var(--ink); margin-bottom:16px; }
.hero__subtitle{ font-size:clamp(1rem,1.5vw,1.13rem); color:var(--ink-soft); line-height:1.75; margin-bottom:28px; max-width:48ch; }
.hero__actions{ display:flex; gap:12px; flex-wrap:wrap; }
.hero__frame{ position:relative; padding:13px; border:1.5px solid var(--secondary); border-radius:calc(var(--radius-card) + 13px); animation:frameIn 700ms cubic-bezier(.16,1,.3,1) both; }
.hero__frame-inner{ border:1.5px solid var(--primary); border-radius:var(--radius-card); overflow:hidden; aspect-ratio:4/3; background:var(--surface); }
.hero__image{ width:100%; height:100%; object-fit:cover; }
@keyframes frameIn{ from{ opacity:0; transform:translateY(14px) scale(.98); } to{ opacity:1; transform:none; } }

/* ============ CATEGORY BAR ============ */
.category-bar{ padding-block:22px; }
.category-bar__scroll{ display:flex; gap:10px; overflow-x:auto; padding-bottom:4px; scrollbar-width:none; }
.category-bar__scroll::-webkit-scrollbar{ display:none; }
.category-pill{
  flex-shrink:0; padding:10px 19px; border-radius:var(--radius-pill); border:1.5px solid var(--border); background:var(--surface);
  font-weight:600; font-size:.88rem; color:var(--ink-soft); transition:all var(--transition);
}
.category-pill:hover{ border-color:var(--primary); color:var(--primary); }
.category-pill.active{ background:var(--primary); border-color:var(--primary); color:#fff; }

/* ============ SECTIONS ============ */
.section-head{ display:flex; align-items:flex-end; justify-content:space-between; gap:12px; margin-bottom:22px; flex-wrap:wrap; }
.section-title{ font-size:clamp(1.35rem,2.4vw,1.8rem); color:var(--ink); }
.section-sub{ color:var(--ink-soft); font-size:.92rem; margin-top:4px; }
.featured-section{ padding-block:36px 8px; }
.products-section{ padding-block:36px 60px; }
.products-toolbar{ display:flex; gap:12px; margin-bottom:22px; flex-wrap:wrap; }
.search-box{ position:relative; flex:1; min-width:200px; }
.search-box input{ width:100%; padding:12px 14px 12px 40px; border:1.5px solid var(--border); border-radius:var(--radius-btn); background:var(--surface); }
.search-box input:focus{ border-color:var(--primary); outline:none; }
.search-box svg{ position:absolute; left:12px; top:50%; transform:translateY(-50%); color:var(--ink-faint); }
.sort-select{ padding:12px 14px; border:1.5px solid var(--border); border-radius:var(--radius-btn); background:var(--surface); color:var(--ink); min-width:150px; }

/* ============ PRODUCT GRID ============ */
.product-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:14px; }
@media(min-width:640px){ .product-grid{ grid-template-columns:repeat(3,1fr); gap:20px; } }
@media(min-width:1024px){ .product-grid{ grid-template-columns:repeat(4,1fr); } }
.product-card{
  background:var(--surface); border-radius:var(--radius-card); overflow:hidden; box-shadow:var(--shadow-sm);
  transition:transform var(--transition), box-shadow var(--transition); cursor:pointer; display:flex; flex-direction:column; position:relative;
}
.product-card:hover{ transform:translateY(-5px); box-shadow:var(--shadow-md); }
.product-card__image-wrap{ aspect-ratio:1/1; overflow:hidden; background:var(--surface-2); position:relative; }
.product-card__image{ width:100%; height:100%; object-fit:cover; transition:transform 450ms; }
.product-card:hover .product-card__image{ transform:scale(1.06); }
.product-card__badge{ position:absolute; top:10px; right:10px; background:var(--secondary); color:#fff; font-size:.68rem; font-weight:800; padding:5px 11px; border-radius:var(--radius-pill); }
.product-card__out{ position:absolute; inset:0; background:rgba(33,26,46,.55); color:#fff; display:flex; align-items:center; justify-content:center; font-weight:700; font-size:.85rem; }
.product-card__body{ padding:13px; display:flex; flex-direction:column; gap:5px; flex:1; }
.product-card__category{ font-size:.68rem; color:var(--ink-faint); font-weight:700; text-transform:uppercase; letter-spacing:.04em; }
.product-card__name{ font-weight:700; font-size:.93rem; line-height:1.4; color:var(--ink); }
.product-card__price-row{ display:flex; align-items:baseline; gap:8px; margin-top:auto; padding-top:6px; flex-wrap:wrap; }
.product-card__price{ font-family:var(--font-display); font-weight:800; color:var(--primary); font-size:1.02rem; }
.product-card__compare{ font-size:.78rem; color:var(--ink-faint); text-decoration:line-through; }
.product-card__add{
  margin-top:9px; width:100%; padding:9px; border-radius:var(--radius-btn); border:1.5px solid var(--primary); background:transparent;
  color:var(--primary); font-weight:700; font-size:.85rem; transition:all var(--transition); display:flex; align-items:center; justify-content:center; gap:6px;
}
.product-card__add:hover{ background:var(--primary); color:#fff; }
.empty-state{ text-align:center; padding:60px 20px; color:var(--ink-soft); }
.empty-state svg{ margin-inline:auto; margin-bottom:14px; color:var(--ink-faint); }

/* ============ PRODUCT MODAL ============ */
.modal-overlay{ position:fixed; inset:0; background:rgba(33,26,46,.5); z-index:700; display:flex; align-items:center; justify-content:center; padding:16px; opacity:0; pointer-events:none; transition:opacity var(--transition); }
.modal-overlay.open{ opacity:1; pointer-events:auto; }
.modal{ background:var(--surface); border-radius:20px; max-width:780px; width:100%; max-height:88vh; overflow-y:auto; box-shadow:var(--shadow-lg); transform:translateY(16px) scale(.98); transition:transform var(--transition); }
.modal-overlay.open .modal{ transform:none; }
.modal__grid{ display:grid; grid-template-columns:1fr; }
@media(min-width:640px){ .modal__grid{ grid-template-columns:1fr 1fr; } }
.modal__image-wrap{ aspect-ratio:1/1; background:var(--surface-2); overflow:hidden; }
.modal__image{ width:100%; height:100%; object-fit:cover; }
.modal__body{ padding:26px; display:flex; flex-direction:column; }
.modal__close{ position:absolute; top:14px; left:14px; background:var(--surface); border-radius:99px; padding:8px; box-shadow:var(--shadow-sm); z-index:2; }
.modal__category{ font-size:.72rem; color:var(--secondary); font-weight:700; text-transform:uppercase; letter-spacing:.04em; margin-bottom:8px; }
.modal__title{ font-size:1.4rem; margin-bottom:10px; }
.modal__desc{ color:var(--ink-soft); line-height:1.8; margin-bottom:18px; font-size:.94rem; }
.modal__price-row{ display:flex; align-items:baseline; gap:10px; margin-bottom:6px; }
.modal__price{ font-family:var(--font-display); font-size:1.6rem; font-weight:800; color:var(--primary); }
.modal__compare{ font-size:.95rem; color:var(--ink-faint); text-decoration:line-through; }
.modal__stock{ font-size:.82rem; color:var(--success); font-weight:600; margin-bottom:20px; }
.modal__stock.out{ color:var(--danger); }
.modal__qty{ display:flex; align-items:center; gap:14px; margin-bottom:18px; }
.modal__qty button{ width:38px; height:38px; border-radius:10px; border:1.5px solid var(--border); background:var(--surface); font-size:1.1rem; font-weight:700; }
.modal__qty button:hover{ border-color:var(--primary); color:var(--primary); }
.modal__qty span{ font-weight:700; min-width:24px; text-align:center; }
.modal__actions{ margin-top:auto; display:flex; gap:10px; }

/* ============ CART DRAWER ============ */
.drawer-backdrop{ position:fixed; inset:0; background:rgba(33,26,46,.45); z-index:600; opacity:0; pointer-events:none; transition:opacity var(--transition); }
.drawer-backdrop.open{ opacity:1; pointer-events:auto; }
.cart-drawer{
  position:fixed; top:0; bottom:0; left:0; width:min(420px,92vw); background:var(--surface); z-index:650; box-shadow:var(--shadow-lg);
  transform:translateX(-100%); transition:transform var(--transition); display:flex; flex-direction:column;
}
.cart-drawer.open{ transform:translateX(0); }
.cart-drawer__head{ display:flex; align-items:center; justify-content:space-between; padding:20px; border-bottom:1px solid var(--border); }
.cart-drawer__head h3{ font-size:1.1rem; }
#cart-drawer-content{ flex:1; overflow-y:auto; padding:18px 20px; display:flex; flex-direction:column; }
.cart-empty{ margin:auto; text-align:center; color:var(--ink-soft); display:flex; flex-direction:column; align-items:center; gap:14px; }
.cart-empty svg{ color:var(--ink-faint); }
.cart-items{ display:flex; flex-direction:column; gap:16px; }
.cart-item{ display:flex; gap:12px; align-items:flex-start; }
.cart-item__image{ width:64px; height:64px; border-radius:10px; object-fit:cover; flex-shrink:0; background:var(--surface-2); }
.cart-item__info{ flex:1; min-width:0; }
.cart-item__name{ font-weight:700; font-size:.88rem; margin-bottom:3px; }
.cart-item__price{ color:var(--primary); font-weight:700; font-size:.85rem; margin-bottom:8px; }
.cart-item__qty{ display:flex; align-items:center; gap:10px; }
.cart-item__qty button{ width:26px; height:26px; border-radius:7px; border:1.5px solid var(--border); background:var(--surface); font-weight:700; }
.cart-item__remove{ background:transparent; color:var(--ink-faint); padding:6px; border-radius:8px; flex-shrink:0; }
.cart-item__remove:hover{ color:var(--danger); background:var(--danger-soft); }
.cart-summary{ border-top:1px solid var(--border); padding-top:16px; margin-top:18px; display:flex; flex-direction:column; gap:14px; }
.cart-summary__row{ display:flex; justify-content:space-between; font-size:1rem; }
.cart-summary__row strong{ font-family:var(--font-display); color:var(--primary); font-size:1.15rem; }

/* ============ CHECKOUT ============ */
.checkout-overlay{ position:fixed; inset:0; background:var(--bg); z-index:800; overflow-y:auto; opacity:0; pointer-events:none; transition:opacity var(--transition); }
.checkout-overlay.open{ opacity:1; pointer-events:auto; }
.checkout-head{ display:flex; align-items:center; gap:14px; padding:18px clamp(16px,4vw,32px); border-bottom:1px solid var(--border); position:sticky; top:0; background:var(--bg); z-index:2; }
.checkout-wrap{ max-width:560px; margin-inline:auto; padding:34px clamp(16px,4vw,32px) 60px; }
.checkout-steps{ display:flex; align-items:center; gap:6px; margin-bottom:32px; }
.checkout-step{ display:flex; align-items:center; gap:8px; font-size:.82rem; font-weight:700; color:var(--ink-faint); }
.checkout-step__dot{ width:26px; height:26px; border-radius:99px; background:var(--surface-2); border:1.5px solid var(--border); display:flex; align-items:center; justify-content:center; font-size:.78rem; }
.checkout-step.active{ color:var(--ink); }
.checkout-step.active .checkout-step__dot{ background:var(--primary); border-color:var(--primary); color:#fff; }
.checkout-step.done .checkout-step__dot{ background:var(--success); border-color:var(--success); color:#fff; }
.checkout-divider{ flex:1; height:1.5px; background:var(--border); }
.checkout-card{ background:var(--surface); border-radius:18px; padding:26px; box-shadow:var(--shadow-sm); }
.order-review{ display:flex; flex-direction:column; gap:10px; margin-bottom:20px; padding-bottom:20px; border-bottom:1px dashed var(--border); }
.order-review__item{ display:flex; justify-content:space-between; font-size:.88rem; color:var(--ink-soft); }
.confirm-box{ text-align:center; }
.confirm-box__icon{ width:64px; height:64px; border-radius:99px; background:var(--success-soft); color:var(--success); display:flex; align-items:center; justify-content:center; margin-inline:auto; margin-bottom:18px; }
.confirm-box__order-id{ font-family:var(--font-display); font-weight:800; font-size:1.3rem; color:var(--primary); margin-bottom:6px; }
.confirm-phone-box{ background:var(--primary-soft); border-radius:14px; padding:20px; margin-block:22px; }
.confirm-phone-box .phone-number{ font-family:var(--font-display); font-size:1.5rem; font-weight:800; color:var(--primary); margin-block:8px; direction:ltr; display:block; }
.confirm-actions{ display:flex; flex-direction:column; gap:10px; }

/* ============ ABOUT / FOOTER ============ */
.about-section{ padding-block:50px; background:var(--surface-2); }
.about-section__inner{ max-width:680px; }
.about-section p{ color:var(--ink-soft); line-height:1.85; margin-top:14px; }
.site-footer{ padding-block:40px 28px; }
.site-footer__inner{ display:flex; flex-direction:column; gap:22px; }
.site-footer__top{ display:flex; flex-wrap:wrap; gap:24px; justify-content:space-between; }
.site-footer__brand{ font-family:var(--font-display); font-weight:800; font-size:1.2rem; }
.site-footer__contacts{ display:flex; flex-wrap:wrap; gap:16px 26px; font-size:.88rem; color:var(--ink-soft); }
.site-footer__contacts a{ display:flex; align-items:center; gap:7px; }
.site-footer__contacts a:hover{ color:var(--primary); }
.site-footer__bottom{ display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:10px; padding-top:18px; border-top:1px solid var(--border); font-size:.78rem; color:var(--ink-faint); }
.site-footer__admin-link{ color:var(--ink-faint); font-size:.78rem; }
.site-footer__admin-link:hover{ color:var(--ink-soft); }

/* ============ ADMIN: LOGIN ============ */
.admin-login{ min-height:100vh; display:flex; align-items:center; justify-content:center; padding:20px; background:var(--ink); }
.admin-login__card{ background:var(--surface); border-radius:20px; padding:38px 32px; width:100%; max-width:380px; box-shadow:var(--shadow-lg); }
.admin-login__logo{ width:52px; height:52px; border-radius:14px; background:var(--primary); display:flex; align-items:center; justify-content:center; color:#fff; margin-bottom:20px; }
.admin-login__card h2{ font-size:1.3rem; margin-bottom:6px; }
.admin-login__card p{ color:var(--ink-soft); font-size:.88rem; margin-bottom:24px; }
.admin-login__back{ display:block; text-align:center; margin-top:16px; color:var(--ink-faint); font-size:.85rem; }
.admin-login__back:hover{ color:var(--ink-soft); }
.admin-login__error{ background:var(--danger-soft); color:var(--danger); padding:11px 14px; border-radius:10px; font-size:.85rem; margin-bottom:16px; display:none; }
.admin-login__error.show{ display:block; }

/* ============ ADMIN: DASHBOARD ============ */
.admin-dashboard{ display:flex; min-height:100vh; background:var(--surface-2); }
.admin-sidebar{
  width:250px; flex-shrink:0; background:var(--ink); color:#EAE6F2; display:flex; flex-direction:column; padding:22px 16px;
  position:fixed; top:0; bottom:0; right:0; z-index:300; transform:translateX(100%); transition:transform var(--transition);
}
.admin-sidebar.open{ transform:translateX(0); }
@media(min-width:920px){ .admin-sidebar{ position:sticky; transform:none; } .admin-main{ margin-right:250px; } }
.admin-sidebar__brand{ display:flex; align-items:center; gap:10px; padding:8px 10px 22px; font-family:var(--font-display); font-weight:800; font-size:1.05rem; border-bottom:1px solid rgba(255,255,255,.1); margin-bottom:14px; }
.admin-sidebar__brand-mark{ width:32px; height:32px; border-radius:9px; background:var(--secondary); display:flex; align-items:center; justify-content:center; flex-shrink:0; }
.admin-nav{ display:flex; flex-direction:column; gap:3px; flex:1; }
.admin-nav button{ display:flex; align-items:center; gap:11px; padding:11px 13px; border-radius:10px; background:transparent; color:#C9C2DC; font-weight:600; font-size:.9rem; text-align:right; width:100%; transition:all var(--transition); }
.admin-nav button:hover{ background:rgba(255,255,255,.07); color:#fff; }
.admin-nav button.active{ background:var(--primary); color:#fff; }
.admin-sidebar__foot{ display:flex; flex-direction:column; gap:3px; padding-top:14px; border-top:1px solid rgba(255,255,255,.1); }
.admin-sidebar__foot a, .admin-sidebar__foot button{ display:flex; align-items:center; gap:11px; padding:11px 13px; border-radius:10px; background:transparent; color:#C9C2DC; font-weight:600; font-size:.9rem; }
.admin-sidebar__foot a:hover, .admin-sidebar__foot button:hover{ background:rgba(255,255,255,.07); color:#fff; }
.admin-main{ flex:1; min-width:0; }
.admin-topbar{ display:flex; align-items:center; gap:14px; padding:16px clamp(16px,3vw,32px); background:var(--surface); border-bottom:1px solid var(--border); position:sticky; top:0; z-index:50; }
.admin-topbar h2{ font-size:1.15rem; flex:1; }
.admin-sidebar-toggle{ display:flex; }
@media(min-width:920px){ .admin-sidebar-toggle{ display:none; } }
.admin-content{ padding:clamp(16px,3vw,32px); max-width:1100px; }
.admin-card{ background:var(--surface); border-radius:16px; padding:24px; box-shadow:var(--shadow-sm); margin-bottom:20px; }
.admin-card h3{ font-size:1rem; margin-bottom:4px; }
.admin-card .card-desc{ color:var(--ink-soft); font-size:.85rem; margin-bottom:20px; }
.admin-card-head{ display:flex; justify-content:space-between; align-items:center; margin-bottom:20px; gap:12px; flex-wrap:wrap; }
.stats-grid{ display:grid; grid-template-columns:repeat(2,1fr); gap:14px; margin-bottom:24px; }
@media(min-width:640px){ .stats-grid{ grid-template-columns:repeat(4,1fr); } }
.stat-card{ background:var(--surface); border-radius:14px; padding:18px; box-shadow:var(--shadow-sm); }
.stat-card__value{ font-family:var(--font-display); font-size:1.7rem; font-weight:800; color:var(--primary); }
.stat-card__label{ font-size:.82rem; color:var(--ink-soft); margin-top:4px; }

/* ============ ADMIN: COLOR PICKERS ============ */
.color-grid{ display:grid; grid-template-columns:repeat(auto-fit,minmax(150px,1fr)); gap:16px; margin-bottom:22px; }
.color-field{ display:flex; flex-direction:column; gap:8px; }
.color-field label{ font-size:.85rem; font-weight:600; color:var(--ink-soft); }
.color-swatch-row{ display:flex; align-items:center; gap:10px; border:1.5px solid var(--border); border-radius:10px; padding:8px 12px; }
.color-swatch-row input[type=color]{ width:36px; height:36px; border:none; border-radius:8px; padding:0; background:none; cursor:pointer; }
.color-swatch-row span{ font-size:.82rem; color:var(--ink-soft); direction:ltr; }
.radius-options{ display:flex; gap:10px; flex-wrap:wrap; }
.radius-option{ flex:1; min-width:90px; border:1.5px solid var(--border); border-radius:12px; padding:14px; text-align:center; background:var(--surface); }
.radius-option.active{ border-color:var(--primary); background:var(--primary-soft); }
.radius-option__preview{ width:36px; height:36px; background:var(--ink-faint); margin-inline:auto; margin-bottom:8px; }
.radius-option span{ font-size:.8rem; font-weight:600; }

/* ============ ADMIN: TABLES / LISTS ============ */
.admin-table{ width:100%; border-collapse:collapse; }
.admin-table th{ text-align:right; font-size:.78rem; color:var(--ink-soft); font-weight:700; padding:10px 12px; border-bottom:1.5px solid var(--border); }
.admin-table td{ padding:12px; border-bottom:1px solid var(--border); font-size:.88rem; vertical-align:middle; }
.admin-table tr:last-child td{ border-bottom:none; }
.table-product{ display:flex; align-items:center; gap:10px; }
.table-product img{ width:42px; height:42px; border-radius:8px; object-fit:cover; background:var(--surface-2); }
.table-actions{ display:flex; gap:6px; }
.badge{ display:inline-flex; padding:4px 10px; border-radius:99px; font-size:.72rem; font-weight:700; }
.badge-success{ background:var(--success-soft); color:var(--success); }
.badge-danger{ background:var(--danger-soft); color:var(--danger); }
.badge-gold{ background:var(--secondary-soft); color:var(--secondary); }
.category-row{ display:flex; align-items:center; justify-content:space-between; padding:11px 6px; border-bottom:1px solid var(--border); gap:10px; }
.category-row:last-child{ border-bottom:none; }
.order-card{ border:1px solid var(--border); border-radius:14px; padding:16px; margin-bottom:12px; }
.order-card__head{ display:flex; justify-content:space-between; align-items:flex-start; gap:10px; cursor:pointer; }
.order-card__id{ font-weight:700; font-family:var(--font-display); }
.order-card__meta{ font-size:.78rem; color:var(--ink-soft); margin-top:3px; }
.order-card__details{ margin-top:14px; padding-top:14px; border-top:1px dashed var(--border); display:none; font-size:.85rem; }
.order-card__details.open{ display:block; }
.order-card__details .row{ display:flex; justify-content:space-between; padding:5px 0; color:var(--ink-soft); }
.order-status-select{ padding:7px 10px; border-radius:8px; border:1.5px solid var(--border); font-size:.78rem; font-weight:700; background:var(--surface); }

/* ============ ADMIN: PRODUCT FORM MODAL ============ */
.admin-modal-overlay{ position:fixed; inset:0; background:rgba(33,26,46,.5); z-index:900; display:flex; align-items:center; justify-content:center; padding:16px; opacity:0; pointer-events:none; transition:opacity var(--transition); overflow-y:auto; }
.admin-modal-overlay.open{ opacity:1; pointer-events:auto; }
.admin-modal{ background:var(--surface); border-radius:18px; max-width:560px; width:100%; padding:28px; max-height:90vh; overflow-y:auto; margin-block:auto; }
.admin-modal h3{ margin-bottom:20px; font-size:1.1rem; }
.image-upload-box{ border:1.5px dashed var(--border); border-radius:14px; padding:18px; text-align:center; cursor:pointer; transition:border-color var(--transition); margin-bottom:16px; }
.image-upload-box:hover{ border-color:var(--primary); }
.image-upload-box img{ max-height:140px; margin-inline:auto; border-radius:10px; margin-bottom:10px; }
.image-upload-box .upload-prompt{ color:var(--ink-soft); font-size:.85rem; display:flex; flex-direction:column; align-items:center; gap:8px; }
.modal-form-actions{ display:flex; gap:10px; margin-top:6px; }

/* ============ UTIL ============ */
.hidden{ display:none !important; }
[hidden]{ display:none !important; }
.empty-list-msg{ text-align:center; color:var(--ink-soft); padding:30px 10px; font-size:.88rem; }
</style>

  if (!p) return;
  const outOfStock = p.stock === 0;
  $('#product-modal-content').innerHTML = `
    <div class="modal__grid">
      <div class="modal__image-wrap"><img class="modal__image" src="${p.image}" alt="${p.name}"></div>

          <div class="cart-item__qty">
            <button onclick="Cart.update(${item.id},${item.qty-1})">−</button>
            <span>${item.qty}</span>
            <button onclick="Cart.update(${item.id},${item.qty+1})">+</button>
          </div>
        </div>
        <button class="cart-item__remove" onclick="Cart.remove(${item.id})" title="حذف">${ICONS.trash}</button>
      </div>`).join('');
    wrap.innerHTML = `<div class="cart-items">${itemsHtml}</div>
      <div class="cart-summary">
        <div class="cart-summary__row"><span>جمع کل</span><strong>${fmtPrice(this.total())}</strong></div>
        <button class="btn btn-primary btn-block" onclick="Cart.close();openCheckout()">تکمیل خرید</button>
        <button class="btn btn-ghost btn-block btn-sm" onclick="Cart.clear()">خالی کردن سبد</button>
      </div>`;
  },
  open() { $('#cart-drawer').classList.add('open'); $('#cart-backdrop').classList.add('open'); document.body.classList.add('no-scroll'); this.render(); },
  close() { $('#cart-drawer').classList.remove('open'); $('#cart-backdrop').classList.remove('open'); document.body.classList.remove('no-scroll'); },

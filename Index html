  const heroImgInput = $('#hero-img-input');
  heroImgInput.onchange = async e => {
    const file = e.target.files[0]; if(!file) return;
    const data = await compressImage(file, 1200);
    $('#cc-hero-image').value = data;
    $('#hero-img-preview').src = data;
  };
}
function saveContent(section) {
  Store.update(d => {
    const s = d.settings;
    if(section==='hero'){ s.heroTitle=$('#cc-hero-title').value; s.heroSubtitle=$('#cc-hero-subtitle').value; s.heroCta=$('#cc-hero-cta').value; s.heroImage=$('#cc-hero-image').value; }
    else if(section==='about'){ s.aboutTitle=$('#cc-about-title').value; s.aboutText=$('#cc-about-text').value; }
    else if(section==='footer'){ s.footerCopy=$('#cc-footer-copy').value; }
  });
  showToast('تغییرات ذخیره شد','toast-success');
}

/* --- APPEARANCE --- */
function renderAdminAppearance() {
  const d = Store.get(); const s = d.settings;
  const colors = s.colors;
  $('#admin-panel-content').innerHTML = `
    <div class="admin-card">
      <h3>رنگ‌های سایت</h3>
      <div class="card-desc">رنگ‌های اصلی سایت را شخصی‌سازی کنید</div>
      <div class="color-grid">
        ${[['bg','رنگ پس‌زمینه'],['surface','رنگ کارت‌ها'],['ink','رنگ متن'],['primary','رنگ اصلی'],['secondary','رنگ ثانویه']].map(([k,l])=>`
        <div class="color-field">
          <label>${l}</label>
          <div class="color-swatch-row">
            <input type="color" id="color-${k}" value="${colors[k]||'#000000'}" oninput="previewColor('${k}',this.value)">
            <span id="color-val-${k}">${colors[k]||'#000000'}</span>
          </div>
        </div>`).join('')}
      </div>
      <div style="margin-bottom:20px">
        <div style="font-size:.85rem;font-weight:600;color:var(--ink-soft);margin-bottom:12px">تم‌های پیش‌ساخته</div>
        <div style="display:flex;gap:10px;flex-wrap:wrap">
          <button class="btn btn-sm btn-outline" onclick="applyTheme('plum')">بنفش کلاسیک</button>
          <button class="btn btn-sm btn-outline" onclick="applyTheme('ocean')">آبی اقیانوس</button>
          <button class="btn btn-sm btn-outline" onclick="applyTheme('forest')">سبز جنگلی</button>
          <button class="btn btn-sm btn-outline" onclick="applyTheme('dark')">تیره</button>
          <button class="btn btn-sm btn-outline" onclick="applyTheme('rose')">رز</button>
        </div>
      </div>
      <button class="btn btn-primary" onclick="saveAppearance()">ذخیره رنگ‌ها</button>
    </div>
    <div class="admin-card">
      <h3>شکل گوشه‌ها</h3>
      <div class="card-desc">انحنای گوشه کارت‌ها و دکمه‌های سایت</div>
      <div class="radius-options">
        <div class="radius-option ${(!s.borderRadius||s.borderRadius==='default')?'active':''}" onclick="selectRadius('default')"><div class="radius-option__preview" style="border-radius:14px"></div><span>پیش‌فرض</span></div>
        <div class="radius-option ${s.borderRadius==='sharp'?'active':''}" onclick="selectRadius('sharp')"><div class="radius-option__preview" style="border-radius:4px"></div><span>تیز</span></div>
        <div class="radius-option ${s.borderRadius==='rounded'?'active':''}" onclick="selectRadius('rounded')"><div class="radius-option__preview" style="border-radius:99px"></div><span>گرد</span></div>
      </div>
    </div>`;
}
let selectedRadius = null;
function selectRadius(val) {
  selectedRadius = val;
  $$('.radius-option').forEach((el,i) => el.classList.toggle('active', ['default','sharp','rounded'][i]===val));
}
function previewColor(key, val) {
  const hexSpan = $(`#color-val-${key}`); if(hexSpan) hexSpan.textContent = val;
  const preview = {}; ['bg','surface','ink','primary','secondary'].forEach(k => { const el=$(`#color-${k}`); if(el) preview[k]=el.value; });
  applyColors(preview);
}
const THEMES = {
  plum: { bg:'#F3F1EB', surface:'#FFFFFF', ink:'#211A2E', primary:'#5C2A52', secondary:'#C28A2E' },
  ocean: { bg:'#EDF4F9', surface:'#FFFFFF', ink:'#0D2B3E', primary:'#1565C0', secondary:'#0097A7' },
  forest: { bg:'#EFF3EE', surface:'#FFFFFF', ink:'#1A2E1C', primary:'#2E6B3E', secondary:'#A67B35' },
  dark: { bg:'#161A1D', surface:'#1E2328', ink:'#EDF0F2', primary:'#7C4DFF', secondary:'#FFD54F' },
  rose: { bg:'#FDF2F4', surface:'#FFFFFF', ink:'#2D1218', primary:'#C2185B', secondary:'#FF8F00' },
};
function applyTheme(name) {
  const t = THEMES[name]; if(!t) return;
  Object.keys(t).forEach(k => { const el=$(`#color-${k}`); if(el){ el.value=t[k]; $(`#color-val-${k}`).textContent=t[k]; } });
  applyColors(t);
}
function saveAppearance() {
  const colors = {};
  ['bg','surface','ink','primary','secondary'].forEach(k => { const el=$(`#color-${k}`); if(el) colors[k]=el.value; });
  Store.update(d => {
    d.settings.colors = colors;
    if(selectedRadius) d.settings.borderRadius = selectedRadius;
  });
  showToast('تنظیمات ظاهری ذخیره شد','toast-success');
  applyColors(colors);
}

/* --- SETTINGS --- */
function renderAdminSettings() {
  const d = Store.get(); const s = d.settings;
  $('#admin-panel-content').innerHTML = `
    <div class="admin-card">
      <h3>اطلاعات فروشگاه</h3>
      <div class="card-desc">اطلاعات کلی که در سراسر سایت نمایش داده می‌شود</div>
      <div class="field"><label>نام فروشگاه</label><input type="text" id="st-name" value="${s.siteName}"></div>
      <div class="field"><label>شماره تماس اصلی</label><input type="tel" id="st-phone" value="${s.phone}" dir="ltr" placeholder="09xxxxxxxxx"></div>
      <div class="field"><label>شماره تماس دوم (اختیاری)</label><input type="tel" id="st-phone2" value="${s.phone2||''}" dir="ltr" placeholder="09xxxxxxxxx"></div>
      <div class="field"><label>ایمیل</label><input type="email" id="st-email" value="${s.email}" dir="ltr"></div>
      <div class="field"><label>آدرس</label><input type="text" id="st-address" value="${s.address}"></div>
      <button class="btn btn-primary" onclick="saveSettings()">ذخیره اطلاعات</button>
    </div>
    <div class="admin-card">
      <h3>امنیت</h3>
      <div class="field"><label>رمز عبور فعلی</label><input type="password" id="st-cur-pass"></div>
      <div class="field"><label>رمز عبور جدید</label><input type="password" id="st-new-pass"></div>
      <div class="field"><label>تکرار رمز جدید</label><input type="password" id="st-confirm-pass"></div>
      <button class="btn btn-primary" onclick="changePassword()">تغییر رمز عبور</button>
    </div>
    <div class="admin-card">
      <h3 style="color:var(--danger)">خطرناک</h3>
      <p class="card-desc">این عملیات برگشت‌پذیر نیست.</p>
      <div style="display:flex;gap:10px;flex-wrap:wrap">
        <button class="btn btn-danger" onclick="resetAllData()">بازنشانی کامل سایت</button>
      </div>
    </div>`;
}
function saveSettings() {
  Store.update(d => {
    d.settings.siteName = $('#st-name').value.trim() || d.settings.siteName;
    d.settings.phone = $('#st-phone').value.trim();
    d.settings.phone2 = $('#st-phone2').value.trim();
    d.settings.email = $('#st-email').value.trim();
    d.settings.address = $('#st-address').value.trim();
  });
  showToast('تنظیمات ذخیره شد','toast-success');
  renderStorefront();
}
function changePassword() {
  const d = Store.get();
  const cur = $('#st-cur-pass').value, nw = $('#st-new-pass').value, conf = $('#st-confirm-pass').value;
  if(cur !== d.settings.adminPassword){ showToast('رمز فعلی اشتباه است','toast-error'); return; }
  if(!nw||nw.length<4){ showToast('رمز جدید باید حداقل ۴ کاراکتر باشد','toast-error'); return; }
  if(nw!==conf){ showToast('رمزهای جدید یکسان نیستند','toast-error'); return; }
  Store.update(d => d.settings.adminPassword = nw);
  showToast('رمز عبور تغییر یافت','toast-success');
  $('#st-cur-pass').value=''; $('#st-new-pass').value=''; $('#st-confirm-pass').value='';
}
function resetAllData() {
  if(!confirm('همه داده‌ها پاک شوند و سایت به حالت اولیه برگردد؟')) return;
  localStorage.removeItem('vitrin_data'); Store._data=null;
  sessionStorage.removeItem('vitrin_admin');
  showToast('سایت بازنشانی شد'); location.reload();
}

/* ===================================================================
   GLOBAL EVENT DELEGATION
=================================================================== */
document.addEventListener('click', e => {
  const el = e.target.closest('[data-action]');
  if (!el) return;
  const action = el.dataset.action;
  if (action === 'open-cart') Cart.open();
  else if (action === 'close-cart') Cart.close();
  else if (action === 'toggle-mobile-nav') { $('#mobile-nav').classList.toggle('open'); document.body.classList.toggle('no-scroll', $('#mobile-nav').classList.contains('open')); }
  else if (action === 'close-modal') closeProductModal();
  else if (action === 'close-checkout') closeCheckout();
  else if (action === 'toggle-admin-sidebar') $('#admin-sidebar').classList.toggle('open');
  else if (action === 'admin-logout') { sessionStorage.removeItem('vitrin_admin'); location.hash=''; goToStorefront(); }
});

document.addEventListener('click', e => {
  if (e.target === $('#product-modal')) closeProductModal();
  if (e.target === $('#admin-modal-overlay')) closeProductForm();
});

/* Close mobile nav on link click */
$$('.mobile-nav a').forEach(a => a.addEventListener('click', () => {
  $('#mobile-nav').classList.remove('open');
  document.body.classList.remove('no-scroll');
}));

/* Admin sidebar link to storefront */
document.addEventListener('click', e => {
  const a = e.target.closest('.admin-sidebar__foot a');
  if (a && !a.href.includes('http')) { e.preventDefault(); goToStorefront(); }
});

/* Header scroll effect */
window.addEventListener('scroll', () => {
  $('#site-header')?.classList.toggle('scrolled', window.scrollY > 10);
}, { passive: true });

/* Search & sort */
document.addEventListener('input', e => {
  if (e.target.id === 'search-input') { searchQuery = e.target.value.trim(); renderProducts(); }
});
document.addEventListener('change', e => {
  if (e.target.id === 'sort-select') { sortMode = e.target.value; renderProducts(); }
});

/* Admin login form */
document.getElementById('admin-login-form').addEventListener('submit', e => {
  e.preventDefault();
  const pw = $('#admin-login-password').value;
  const d = Store.get();
  if (pw === d.settings.adminPassword) {
    $('#admin-login-error').classList.remove('show');
    showAdminDashboard();
  } else {
    $('#admin-login-error').classList.add('show');
  }
});

/* Admin login back link */
document.querySelector('.admin-login__back').addEventListener('click', e => {
  e.preventDefault(); goToStorefront();
});

/* Footer admin link */
document.querySelector('.site-footer__admin-link').addEventListener('click', e => {
  e.preventDefault(); goToAdmin();
});

/* Hash routing */
function handleHash() {
  if (location.hash === '#admin') goToAdmin();
  else goToStorefront();
}
window.addEventListener('hashchange', handleHash);
window.addEventListener('popstate', () => {
  if (location.hash !== '#admin') goToStorefront();
});

/* ===================================================================
   BOOT
=================================================================== */
handleHash();

/* Keyboard: close modals with Escape */
document.addEventListener('keydown', e => {
  if (e.key === 'Escape') {
    closeProductModal(); Cart.close(); closeCheckout();
    $('#mobile-nav').classList.remove('open');
    document.body.classList.remove('no-scroll');
  }
});
</script>
</body>
</html>

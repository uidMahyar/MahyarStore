function applyColors(colors) {
  const r = document.documentElement.style;
  if (colors.bg) r.setProperty('--bg', colors.bg);
  if (colors.surface) r.setProperty('--surface', colors.surface);
  if (colors.ink) { r.setProperty('--ink', colors.ink); }
  if (colors.primary) { r.setProperty('--primary', colors.primary); r.setProperty('--primary-dark', shadeColor(colors.primary,-15)); r.setProperty('--primary-soft', hexToAlpha(colors.primary,0.12)); }
  if (colors.secondary) { r.setProperty('--secondary', colors.secondary); r.setProperty('--secondary-soft', hexToAlpha(colors.secondary,0.15)); }
}
function shadeColor(hex, pct) {
  let c = hex.slice(1); if (c.length===3) c=c[0]+c[0]+c[1]+c[1]+c[2]+c[2];
  const n=parseInt(c,16),r=Math.max(0,Math.min(255,(n>>16)+pct)),g=Math.max(0,Math.min(255,((n>>8)&0xff)+pct)),b=Math.max(0,Math.min(255,(n&0xff)+pct));
  return '#'+((1<<24)+(r<<16)+(g<<8)+b).toString(16).slice(1);
}
function hexToAlpha(hex, a) {
  const r=parseInt(hex.slice(1,3),16),g=parseInt(hex.slice(3,5),16),b=parseInt(hex.slice(5,7),16);
  return `rgba(${r},${g},${b},${a})`;
}


          ${p.comparePrice ? `<span class="modal__compare">${fmtPrice(p.comparePrice)}</span>` : ''}
        </div>
        <div class="modal__stock ${outOfStock?'out'}">${outOfStock ? 'ناموجود' : 'موجود'}</div>
        ${!outOfStock ? `
        <div class="modal__qty">
          <span style="font-size:.85rem;color:var(--ink-soft)">تعداد:</span>
          <button id="modal-qty-dec">−</button>
          <span id="modal-qty-val">1</span>
          <button id="modal-qty-inc">+</button>
        </div>
        <div class="modal__actions">
          <button class="btn btn-primary" style="flex:1" id="modal-add-btn">افزودن به سبد</button>
        </div>` : '<button class="btn btn-outline btn-block" disabled>ناموجود</button>'}
      </div>
    </div>`;
  let qty = 1;
  const qv = $('#modal-qty-val'), dec = $('#modal-qty-dec'), inc = $('#modal-qty-inc'), addBtn = $('#modal-add-btn');
  if (dec) dec.onclick = () => { if(qty>1){ qty--; qv.textContent=qty; } };
  if (inc) inc.onclick = () => { if(qty<p.stock){ qty++; qv.textContent=qty; } };
  if (addBtn) addBtn.onclick = () => { Cart.add(p, qty); closeProductModal(); showToast(`${p.name} به سبد اضافه شد`, 'toast-success'); };
  $('#product-modal').classList.add('open');
